# =============================================================================
# REVIEWER GITHUB APPS (required for /pr-review, /ship, /cage-match)
# =============================================================================
# Each reviewer is a GitHub App. You need the App ID and a base64-encoded
# private key for each. See README.md "Setup (Your Own Projects)" for details.
#
# Team members: get these values from your team lead.

# MaxwellMergeSlam - Claude reviewer (for /pr-review, /ship, /cage-match)
MAXWELL_APP_ID=
MAXWELL_PRIVATE_KEY_B64=

# KelvinBitBrawler - Gemini reviewer (for /cage-match)
KELVIN_APP_ID=
KELVIN_PRIVATE_KEY_B64=

# =============================================================================
# OPTIONAL - Only needed for specific skills
# =============================================================================

# For /pm skill - GitHub PAT for claude-pm-enspyr account
# Required scopes: repo, project
CLAUDE_PM_PAT=ghp_your_token_here

# For /slides skill - Google OAuth2 Credentials
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# =============================================================================
# ADMIN ONLY (enspyrco) - For setting up new repos
# =============================================================================

# GitHub PAT for enspyr-admin account (for /ship repo setup)
# Used to configure branch protection on enspyrco repos
# Team members and external users don't need this
ENSPYR_ADMIN_PAT=ghp_your_token_here
