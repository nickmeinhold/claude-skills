# =============================================================================
# TEAM MEMBER SETUP (required)
# =============================================================================
# Get these from your team lead

# MaxwellMergeSlam GitHub App (Claude reviewer - for /pr-review, /ship, /cage-match)
MAXWELL_APP_ID=123456
MAXWELL_PRIVATE_KEY_B64=base64-encoded-pem-here

# KelvinBitBrawler GitHub App (Gemini reviewer - for /cage-match)
KELVIN_APP_ID=789012
KELVIN_PRIVATE_KEY_B64=base64-encoded-pem-here

# =============================================================================
# OPTIONAL - Only needed for specific skills
# =============================================================================

# For /pm skill - GitHub PAT for claude-pm-enspyr account
# Required scopes: repo, project
CLAUDE_PM_PAT=ghp_your_token_here

# For /slides skill - Google OAuth2 Credentials
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# =============================================================================
# ADMIN ONLY - For setting up new repos
# =============================================================================

# GitHub PAT for enspyr-admin account (for /ship repo setup)
# Used to configure branch protection on nickmeinhold repos
# Team members don't need this - only repo admins setting up new repos
ENSPYR_ADMIN_PAT=ghp_your_token_here
